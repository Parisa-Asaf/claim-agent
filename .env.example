# ============================================
# ACRLE — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/acrle_db"

# OpenAI API — Feature 4: Statute Lookup
OPENAI_API_KEY="sk-..."

# Google Vision API — Feature 1: Evidence Extraction
# Get from: https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY="AIza..."

# Google Maps API — Feature 3: Company Intelligence
# Get from: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_MAPS_API_KEY="AIza..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
