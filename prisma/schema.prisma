generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Evidence {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  fileName        String
  fileSize        Int
  mimeType        String
  fileUrl         String?
  merchantName    String?
  transactionDate DateTime?
  amount          Float?
  currency        String?   @default("USD")
  rawExtraction   Json?
  confidenceScore Float?
  sha256Hash      String    @unique
  hashAlgorithm   String    @default("SHA-256")
  hashVerified    Boolean   @default(true)
  hashTimestamp   DateTime  @default(now())
  claimId         String?
  claim           Claim?    @relation(fields: [claimId], references: [id])

  @@map("evidence")
}

model Company {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  name        String
  email       String?
  legalDept   String?
  address     String
  city        String?
  country     String
  countryCode String   @db.VarChar(2)
  industry    String?
  website     String?
  latitude    Float?
  longitude   Float?
  placeId     String?
  verified    Boolean  @default(false)
  claims      Claim[]

  @@map("companies")
}

model StatuteLookup {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  grievanceText String   @db.Text
  grievanceType String?
  jurisdiction  String
  rawResponse   Json
  statutes      Json
  claimId       String?
  claim         Claim?   @relation(fields: [claimId], references: [id])

  @@map("statute_lookups")
}

model Claim {
  id             String        @id @default(uuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  title          String?
  status         ClaimStatus   @default(DRAFT)
  grievanceText  String?       @db.Text
  grievanceType  String?
  violationType  String?
  priorityLevel  PriorityLevel @default(MEDIUM)
  expirationDate DateTime?
  notes          String?       @db.Text
  evidences      Evidence[]
  statutes       StatuteLookup[]
  companyId      String?
  company        Company?      @relation(fields: [companyId], references: [id])

  @@map("claims")
}

model User {
  id         String     @id @default(uuid())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  name       String
  email      String     @unique
  role       UserRole   @default(LEGAL_EXPERT)
  isActive   Boolean    @default(true)
  assignedBy String?
  auditLogs  AuditLog[]

  @@map("users")
}

model AuditLog {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  action      String
  entity      String
  entityId    String?
  details     Json?
  performedBy String?
  ipAddress   String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum ClaimStatus {
  DRAFT
  EVIDENCE_COLLECTED
  STATUTES_MATCHED
  READY_FOR_DISPATCH
  DISPATCHED
}

enum PriorityLevel {
  HIGH
  MEDIUM
  LOW
}

enum UserRole {
  ADMIN
  LEGAL_EXPERT
  VIEWER
}