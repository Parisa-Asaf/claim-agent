generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Grievance {
  id          Int             @id @default(autoincrement())
  caseId      String          @unique
  title       String
  description String
  location    String?
  category    String?
  documentUrl String?
  createdAt   DateTime        @default(now())
  timeline    TimelineEvent[]
}

model TimelineEvent {
  id          Int       @id @default(autoincrement())
  caseId      String
  title       String
  description String
  eventDate   DateTime  @default(now())
  fileName    String?
  grievance   Grievance @relation(fields: [caseId], references: [caseId], onDelete: Cascade)
}