// Prisma Schema — ACRLE Module 1
// Run: npx prisma db push  OR  npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── MODULE 1: FOUNDATION & VERIFICATION ─────────────────────────────────────

// Feature 1 & 2: Uploaded evidence files with extracted data + hash
model Evidence {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // File metadata
  fileName      String
  fileSize      Int
  mimeType      String
  fileUrl       String?  // S3 / local path

  // Feature 1: Vision API extracted fields
  merchantName  String?
  transactionDate DateTime?
  amount        Float?
  currency      String?  @default("USD")
  rawExtraction Json?    // full Vision API response
  confidenceScore Float? // avg confidence 0–100

  // Feature 2: SHA-256 hash for tamper-proofing
  sha256Hash    String   @unique
  hashAlgorithm String   @default("SHA-256")
  hashVerified  Boolean  @default(true)
  hashTimestamp DateTime @default(now())

  // Relations
  claimId       String?
  claim         Claim?   @relation(fields: [claimId], references: [id])

  @@map("evidence")
}

// Feature 3: Corporate legal directory entries
model Company {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  name          String
  legalDept     String?
  address       String
  city          String?
  country       String
  countryCode   String   @db.VarChar(2)
  industry      String?
  website       String?
  latitude      Float?
  longitude     Float?
  placeId       String?  // Google Maps Place ID
  verified      Boolean  @default(false)

  // Relations
  claims        Claim[]

  @@map("companies")
}

// Feature 4: Statute lookup results
model StatuteLookup {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  grievanceText String   @db.Text
  grievanceType String?
  jurisdiction  String
  rawResponse   Json     // full OpenAI response
  statutes      Json     // parsed statutes array

  // Relations
  claimId       String?
  claim         Claim?   @relation(fields: [claimId], references: [id])

  @@map("statute_lookups")
}

// Master claim record linking all Module 1 artifacts
model Claim {
  id            String      @id @default(uuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  title         String?
  status        ClaimStatus @default(DRAFT)
  grievanceText String?     @db.Text
  grievanceType String?

  // Feature 2: Claim Triage fields
  violationType    String?
  priorityLevel    PriorityLevel @default(MEDIUM)
  expirationDate   DateTime?
  notes            String?   @db.Text

  // Relations
  evidences     Evidence[]
  statutes      StatuteLookup[]
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
  demandLetters DemandLetter[]
  settlements   Settlement[]
  outcome       ClaimOutcome?

  @@map("claims")
}

// Feature 5: Automated Letter Architect — Demand Letters
model DemandLetter {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  senderName    String
  senderAddress String   @db.Text
  senderEmail   String?
  senderPhone   String?
  recipientName String
  recipientAddress String @db.Text
  
  letterContent String   @db.Text
  selectedStatutes Json?   // Specific statutes chosen by user
  pdfUrl        String?  // If stored externally

  // Relations
  claimId       String
  claim         Claim    @relation(fields: [claimId], references: [id])

  @@map("demand_letters")
}

// Feature 3 (Module 3): Recovery Dashboard — settlement offers & outcomes
model Settlement {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  claimId         String
  claim           Claim            @relation(fields: [claimId], references: [id])

  // Company response text (raw)
  companyResponse String           @db.Text

  // AI analysis result
  aiVerdict       SettlementVerdict
  fairnessScore   Int              // 0–100
  aiExplanation   String           @db.Text
  recommendedAction String         @db.Text
  comparableOutcomes Json?         // array of past similar cases

  // Actual outcome (filled by user later)
  outcome         SettlementOutcome @default(PENDING)
  finalAmount     Float?
  currency        String?          @default("BDT")

  @@map("settlements")
}

// Feature 3 (Module 3): Recovery Dashboard stats helper
model ClaimOutcome {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())

  claimId       String    @unique
  claim         Claim     @relation(fields: [claimId], references: [id])

  // Recovery data
  claimedAmount    Float
  recoveredAmount  Float?
  currency         String   @default("BDT")
  isRecovered      Boolean  @default(false)
  closedAt         DateTime?

  @@map("claim_outcomes")
}

enum ClaimStatus {
  DRAFT
  EVIDENCE_COLLECTED
  STATUTES_MATCHED
  READY_FOR_DISPATCH
  SENT
  RESPONSE_RECEIVED
  SETTLED
  CLOSED
}

enum PriorityLevel {
  HIGH
  MEDIUM
  LOW
}

enum SettlementVerdict {
  FAIR
  UNFAIR
  PARTIAL
  INVESTIGATE
}

enum SettlementOutcome {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  ESCALATED
}
